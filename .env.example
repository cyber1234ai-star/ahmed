# PostgreSQL / Supabase Postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/graphic_portfolio?schema=public"

# Required in production. Generate with: openssl rand -base64 32
SESSION_SECRET="replace-with-a-long-random-secret"
# For local `next start` over http only. Keep true/omitted in real HTTPS production.
AUTH_COOKIE_SECURE="false"

# Optional: Supabase Storage. If omitted, uploads are saved to public/uploads for local development.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="portfolio"

# Optional local fallback switch.
# USE_LOCAL_DB=true
